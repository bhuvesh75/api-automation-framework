{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "User List Response",
  "description": "Schema for the GET /api/users?page=N paginated response from reqres.in",
  "type": "object",
  "required": ["page", "per_page", "total", "total_pages", "data", "support"],
  "additionalProperties": false,
  "properties": {
    "page": {
      "type": "integer",
      "description": "Current page number"
    },
    "per_page": {
      "type": "integer",
      "description": "Number of records returned per page"
    },
    "total": {
      "type": "integer",
      "description": "Total number of user records across all pages"
    },
    "total_pages": {
      "type": "integer",
      "description": "Total number of available pages"
    },
    "data": {
      "type": "array",
      "description": "Array of user objects for the current page",
      "items": {
        "type": "object",
        "required": ["id", "email", "first_name", "last_name", "avatar"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "integer",
            "description": "Unique numeric identifier for the user"
          },
          "email": {
            "type": "string",
            "format": "email",
            "description": "Email address of the user"
          },
          "first_name": {
            "type": "string",
            "description": "First name of the user"
          },
          "last_name": {
            "type": "string",
            "description": "Last name of the user"
          },
          "avatar": {
            "type": "string",
            "format": "uri",
            "description": "URL to the user avatar image"
          }
        }
      }
    },
    "support": {
      "type": "object",
      "description": "Support information included in every response",
      "required": ["url", "text"],
      "additionalProperties": false,
      "properties": {
        "url": {
          "type": "string",
          "format": "uri",
          "description": "URL to the support page"
        },
        "text": {
          "type": "string",
          "description": "Support message text"
        }
      }
    }
  }
}
