# Target API base URL — all requests are relative to this
BASE_URL=https://reqres.in/api

# API key for reqres.in — obtain a free key at https://app.reqres.in/signup
API_KEY=your-api-key-here

# Maximum acceptable response time in milliseconds
RESPONSE_TIMEOUT_MS=2000

# Default page number for paginated list tests
DEFAULT_PAGE=2
